
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user's profile and financial status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "state": { "type": "string" },
        "age": { "type": "number" },
        "income": { "type": "number" },
        "occupation": { "type": "string" },
        "casteCategory": { "type": "string" },
        "gender": { "type": "string" },
        "familySize": { "type": "number" },
        "disabilityStatus": { "type": "boolean" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "aiCategory": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "date"]
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transaction records."
    }
  }
}
